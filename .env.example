# Local dev / integration-test Postgres (used by docker-compose.yml).
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password_here
POSTGRES_DB=querylens
POSTGRES_PORT=55432

# Set entire database URL with password here instead of in config (.query-lens.yml). 
# Set db.url in config to ${DATABASE_URL} to use this.
DATABASE_URL=postgres://your_db_user:your_db_password_here@localhost:55432/querylens

# Alternatively, set db.url without password in config (.query-lens.yml) and set password here.
# postgres://app:${DB_PASSWORD}@localhost:5432/mydb
DB_PASSWORD=your_db_password_here

# LLM provider API keys (only the one for your configured llm.provider is needed).
ANTHROPIC_API_KEY=sk-ant-...
AZURE_API_KEY=...
