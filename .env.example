# Local dev / integration-test Postgres (used by docker-compose.yml).
POSTGRES_USER=querylens
POSTGRES_PASSWORD=querylens
POSTGRES_DB=querylens
POSTGRES_PORT=55432

# Consumed by the opt-in DB integration tests (RUN_DB_TESTS=1).
DATABASE_URL=postgres://querylens:querylens@localhost:55432/querylens

# LLM provider API keys (only the one for your configured llm.provider is needed).
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=...   # used with llm.provider=azure + llm.resourceName in .query-lens.yml
